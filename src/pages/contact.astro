---
import BrandGithub from '@tabler/icons/outline/brand-github.svg';
import Mail from '@tabler/icons/outline/mail.svg';
import BrandX from '@tabler/icons/outline/brand-x.svg';
import { Badge } from '@/components/starwind/badge';
import { Button } from '@/components/starwind/button';
import SiteLayout from '@/components/SiteLayout.astro';
import { fallbackPages, getEntry } from '@/lib/content';

const page = await getEntry('pages', 'contact', fallbackPages);
---

<SiteLayout title="Contact" description={page?.description}>
  <section class="mx-auto grid max-w-3xl gap-8 px-5 py-16">
    <div class="grid content-start gap-5">
      <Badge variant="outline">{page?.kicker ?? 'Contact'}</Badge>
      <h1 class="text-4xl font-semibold leading-tight md:text-5xl">{page?.title}</h1>
      <p class="text-lg leading-8 text-muted-foreground">{page?.description}</p>
      <p class="leading-8">{page?.body}</p>
      <div class="flex flex-wrap gap-3">
        <Button href="mailto:samuel.paluba@thinkhome.org">
          <Mail />
          Email
        </Button>
        <Button href="https://github.com/SamuelPalubaCZ" variant="outline">
          <BrandGithub />
          GitHub
        </Button>
        <Button href="https://x.com/PalubaSamuel" variant="outline">
          <BrandX />
          X
        </Button>
      </div>
    </div>
  </section>
</SiteLayout>
