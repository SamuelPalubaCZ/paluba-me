---
import { ThemeToggle } from '@/components/starwind/theme-toggle';
import '../styles/starwind.css';

type NavItem = {
  href: string;
  label: string;
};

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Samuel Paluba',
  description = 'Personal website for work, writing, and open technology.',
} = Astro.props;

const navItems: NavItem[] = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/work', label: 'Work' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const pageTitle = title === 'Samuel Paluba' ? title : `${title} | Samuel Paluba`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <title>{pageTitle}</title>
    <script is:inline>
      function initTheme() {
        const colorTheme = localStorage.getItem("colorTheme");
        if (!colorTheme) {
          const prefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", prefersDark);
          localStorage.setItem("colorTheme", prefersDark ? "dark" : "light");
          return;
        }

        if (colorTheme === "system") {
          const prefersDark =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", prefersDark);
          return;
        }

        document.documentElement.classList.toggle("dark", colorTheme === "dark");
      }

      initTheme();
      document.addEventListener("astro:after-swap", initTheme);
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <div class="min-h-screen">
      <header class="sticky top-0 z-40 border-b bg-background/90 backdrop-blur">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-4 gap-y-2 px-5 py-3">
          <a href="/" class="font-heading text-base font-semibold">
            Samuel Paluba
          </a>
          <nav
            class="order-3 flex w-full items-center gap-1 overflow-x-auto border-t pt-2 md:order-none md:w-auto md:border-0 md:pt-0"
            aria-label="Primary navigation"
          >
            {
              navItems.map((item) => {
                const active =
                  item.href === '/' ? currentPath === '/' : currentPath.startsWith(item.href);
                return (
                  <a
                    href={item.href}
                    aria-current={active ? 'page' : undefined}
                    class:list={[
                      'rounded-md px-3 py-2 text-sm transition-colors',
                      active
                        ? 'bg-muted text-foreground'
                        : 'text-muted-foreground hover:bg-muted hover:text-foreground',
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </nav>
          <div class="flex items-center gap-2">
            <ThemeToggle size="sm" />
          </div>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="border-t">
        <div class="mx-auto grid max-w-6xl gap-4 px-5 py-8 text-sm text-muted-foreground md:grid-cols-[1fr_auto]">
          <p>Samuel Paluba. Built with Astro, EmDash, Starwind UI, and Cloudflare.</p>
          <div class="flex flex-wrap gap-3">
            <a href="https://github.com/SamuelPalubaCZ" class="hover:text-foreground">GitHub</a>
            <a href="https://x.com/PalubaSamuel" class="hover:text-foreground">X</a>
            <a href="/_emdash/admin" class="hover:text-foreground">Admin</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
